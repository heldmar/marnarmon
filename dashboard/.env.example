# Copy to .env and adjust, then: docker compose --env-file .env up -d
# (or set these directly in docker-compose.yml)

# Browser-facing API base. "/api" = same-origin reverse proxy (nginx forwards
# /api/ to API_UPSTREAM). Use this when the dashboard is served over public
# HTTPS so it works off the LAN. For LAN-only access you can instead set a full
# URL (e.g. http://192.168.4.200:8787) and ignore API_UPSTREAM.
API_BASE_URL=/api

# Where nginx forwards /api/ — the host agent as reached FROM THE CONTAINER
# (host LAN IP, reachable on the Docker network). Only used in same-origin mode.
API_UPSTREAM=http://192.168.4.200:8787

# Dashboard poll interval in seconds.
REFRESH_SECONDS=300

# Bearer token if the host API has auth enabled; leave empty if not.
API_TOKEN=
